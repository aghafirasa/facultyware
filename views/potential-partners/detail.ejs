<!doctype html>
<html lang="id">
  <head>
    <script>
      (() => {
        try {
          const s = localStorage.getItem('themeMode');
          if (s ? s === 'dark' : matchMedia('(prefers-color-scheme: dark)').matches)
            document.documentElement.classList.add('dark');
        } catch(_) {}
        document.addEventListener('basecoat:theme', e => {
          const m = e.detail?.mode;
          const dark = m === 'dark' ? true : m === 'light' ? false : !document.documentElement.classList.contains('dark');
          document.documentElement.classList.toggle('dark', dark);
          try { localStorage.setItem('themeMode', dark ? 'dark' : 'light'); } catch(_) {}
        });
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Detail Potential Partner - Facultyware</title>
    <meta name="description" content="Detail informasi data potential partner." />
    <link rel="stylesheet" href="/assets/styles.css?v=2" />
  </head>
  <body>
    <!-- ===== SIDEBAR ===== -->
    <aside id="sidebar" class="sidebar" data-side="left">
      <nav aria-label="Sidebar navigation">
        <header>
          <a href="/home" class="btn-ghost p-2 h-12 w-full justify-start">
            <div class="bg-sidebar-primary text-sidebar-primary-foreground flex aspect-square size-8 items-center justify-center rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div class="grid flex-1 text-left text-sm leading-tight ml-2">
              <span class="truncate font-semibold">Facultyware</span>
              <span class="truncate text-xs opacity-60">Sistem Informasi Fakultas</span>
            </div>
          </a>
        </header>
        <section>
          <div role="group" aria-labelledby="nav-main">
            <h3 id="nav-main">Menu Utama</h3>
            <ul>
              <li><a href="/home"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg><span>Dashboard</span></a></li>
              <li><a href="/potential-partners" aria-current="page"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg><span>Potential Partner</span></a></li>
              <li>
                <a href="/mou">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                  <span>Draft MoU</span>
                </a>
              </li>
              <li>
                <a href="/follow-up">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                  <span>Follow Up</span>
                </a>
              </li>
            </ul>
          </div>
        </section>
        <footer>
          <div class="px-3 py-2">
            <div class="flex items-center gap-3 rounded-md px-2 py-2 text-sm">
              <div class="flex aspect-square size-8 items-center justify-center rounded-full bg-primary text-primary-foreground text-xs font-bold">
                <%= user ? user.charAt(0).toUpperCase() : 'A' %>
              </div>
              <div class="grid flex-1 text-left leading-tight">
                <span class="truncate text-sm font-medium"><%= user || 'Admin' %></span>
              </div>
            </div>
            <a href="/logout" class="btn btn-ghost w-full justify-start mt-1 text-sm gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>
              Keluar
            </a>
          </div>
        </footer>
      </nav>
    </aside>

    <!-- ===== MAIN ===== -->
    <main class="flex-1 flex flex-col min-h-screen" style="margin-left:var(--sidebar-width,16rem)">
      <!-- Topbar -->
      <header class="border-b bg-background sticky top-0 z-10">
        <div class="flex h-14 items-center gap-4 px-6">
          <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-sm text-muted-foreground">
            <a href="/home" class="hover:text-foreground">Dashboard</a>
            <span>/</span>
            <a href="/potential-partners" class="hover:text-foreground">Potential Partner</a>
            <span>/</span>
            <span class="text-foreground font-medium">Detail</span>
          </nav>
        </div>
      </header>

      <!-- Page Content -->
      <div class="flex-1 p-6">
        <div class="max-w-2xl mx-auto space-y-6">

          <!-- Page Header -->
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <a href="/potential-partners" class="btn btn-ghost btn-icon" aria-label="Kembali">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
              </a>
              <div>
                <h1 class="text-xl font-bold">Detail Potential Partner</h1>
                <p class="text-sm text-muted-foreground">
                  ID Mitra: <strong><%= potentialPartner.id %></strong>
                </p>
              </div>
            </div>
            <a href="/potential-partners/edit/<%= potentialPartner.id %>" class="btn btn-primary gap-2 btn-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/></svg>
              Edit Data
            </a>
          </div>

          <!-- Main Info Card -->
          <div class="card">
            <div class="card-header border-b py-4">
              <h2 class="card-title text-base">Informasi Lengkap Mitra</h2>
              <p class="card-description">Profil detail calon mitra strategic fakultas</p>
            </div>
            <div class="card-content p-6 space-y-6">
              
              <!-- Grid Detail Fields -->
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4">
                
                <div>
                  <span class="text-xs text-muted-foreground font-semibold block uppercase tracking-wider">Nama Perusahaan</span>
                  <span class="text-base font-bold text-foreground mt-0.5 block"><%= potentialPartner.company_name %></span>
                </div>

                <div>
                  <span class="text-xs text-muted-foreground font-semibold block uppercase tracking-wider">Status Kerjasama</span>
                  <div class="mt-1">
                    <% 
                      const statusBadge = {identified:'badge-info', in_discussion:'badge-warning', proposed:'badge-secondary', converted:'badge-success', rejected:'badge-destructive'};
                      const statusLabel = {identified:'Teridentifikasi', in_discussion:'Dalam Diskusi', proposed:'Diajukan', converted:'Kerjasama (Aktif)', rejected:'Ditolak'}; 
                    %>
                    <span class="badge <%= statusBadge[potentialPartner.status] || 'badge-outline' %> text-xs font-semibold px-2.5 py-1">
                      <%= statusLabel[potentialPartner.status] || potentialPartner.status %>
                    </span>
                  </div>
                </div>

                <div>
                  <span class="text-xs text-muted-foreground font-semibold block uppercase tracking-wider">Contact Person</span>
                  <span class="text-sm text-foreground mt-0.5 block"><%= potentialPartner.contact_person || '-' %></span>
                </div>

                <div>
                  <span class="text-xs text-muted-foreground font-semibold block uppercase tracking-wider">Tipe Partnership</span>
                  <div class="mt-1">
                    <% 
                      const typeColors = {university:'badge-info', company:'badge-warning', government:'badge-secondary', ngo:'badge-success', other:'badge-outline'};
                      const typeLabels = {university:'Academic', company:'Industry', government:'Research', ngo:'NGO', other:'Other'}; 
                    %>
                    <span class="badge <%= typeColors[potentialPartner.partnership_type] || 'badge-outline' %> text-xs px-2.5 py-0.5">
                      <%= typeLabels[potentialPartner.partnership_type] || potentialPartner.partnership_type || '-' %>
                    </span>
                  </div>
                </div>

                <div>
                  <span class="text-xs text-muted-foreground font-semibold block uppercase tracking-wider">Email</span>
                  <% if (potentialPartner.email) { %>
                    <a href="mailto:<%= potentialPartner.email %>" class="text-sm text-primary hover:underline mt-0.5 block"><%= potentialPartner.email %></a>
                  <% } else { %>
                    <span class="text-sm text-muted-foreground mt-0.5 block">-</span>
                  <% } %>
                </div>

                <div>
                  <span class="text-xs text-muted-foreground font-semibold block uppercase tracking-wider">Nomor Telepon</span>
                  <span class="text-sm text-foreground mt-0.5 block"><%= potentialPartner.phone || '-' %></span>
                </div>

                <div class="sm:col-span-2">
                  <span class="text-xs text-muted-foreground font-semibold block uppercase tracking-wider">Alamat Perusahaan</span>
                  <span class="text-sm text-foreground mt-0.5 block leading-relaxed"><%= potentialPartner.address || '-' %></span>
                </div>

                <div class="sm:col-span-2">
                  <span class="text-xs text-muted-foreground font-semibold block uppercase tracking-wider">Deskripsi Kemitraan</span>
                  <span class="text-sm text-foreground mt-0.5 block leading-relaxed whitespace-pre-line"><%= potentialPartner.description || '-' %></span>
                </div>

              </div>

              <div class="border-t pt-5 mt-4 grid grid-cols-2 gap-4 text-xs text-muted-foreground">
                <div>
                  <span>Dibuat Pada:</span>
                  <strong class="text-foreground block mt-0.5 font-medium"><%= potentialPartner.created_at ? new Date(potentialPartner.created_at).toLocaleString('id-ID', {day:'2-digit',month:'long',year:'numeric',hour:'2-digit',minute:'2-digit'}) : '-' %></strong>
                </div>
                <div>
                  <span>Terakhir Diperbarui:</span>
                  <strong class="text-foreground block mt-0.5 font-medium"><%= potentialPartner.updated_at ? new Date(potentialPartner.updated_at).toLocaleString('id-ID', {day:'2-digit',month:'long',year:'numeric',hour:'2-digit',minute:'2-digit'}) : '-' %></strong>
                </div>
              </div>

            </div>
          </div>

          <div class="flex items-center gap-3">
            <a href="/potential-partners" class="btn btn-outline flex-1 sm:flex-none">Kembali ke Daftar</a>
          </div>

        </div>
      </div>
    </main>

    <script src="/assets/js/basecoat.js" defer></script>
  </body>
</html>
